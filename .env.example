# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/warehouse_pro"

# NextAuth - IMPORTANT: Set a secure secret in production
# Generate one with: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-key-here-change-this-in-production"
NEXTAUTH_URL="http://localhost:3000"

# For GitHub Codespaces, uncomment and set:
# NEXTAUTH_URL="https://your-codespace-url.github.dev"

# OAuth (optional - leave empty to disable)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# OpenAI (for AI Assistant - optional)
OPENAI_API_KEY=""

# Stripe (for billing - optional)
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# App Settings
NODE_ENV="development"
